---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Hr from '@components/Hr.astro';
import BlogStats from '@components/BlogStats.astro';
import MostReadAndTopics from '@components/MostReadAndTopics.astro';
import Card from '@components/Card';
import Socials from '@components/Socials.astro';
import getSortedPosts from '@utils/getSortedPosts';
import { SOCIALS } from '@config';

const posts = await getCollection('blog');

const sortedPosts = await getSortedPosts(posts);
// const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>Aman Mittal <span class="username">@amanhimself</span></h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="rss-link"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="rss-icon"
          ><path
            d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z"
          ></path><path
            d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z"
          ></path><circle cx="6" cy="18" r="2"></circle>
        </svg>
        <span class="sr-only">RSS Feed</span>
      </a>
      <div class="text-lg">
        <p class="flex">
          I'm currently working on documentation as a consultant at Expo.
          <p>
            I love crafting documentation and writing about programming. I've
            been writing about cross-platform mobile and web development since
            2017, with over 150 articles for 30+ publications.
          </p>
          <p>
            Previously, worked as Developer Advocate at Draftbit, and Senior
            Content Developer at Vercel.
          </p>
          <p>
            See what I'm up to on my <a
              href="/now"
              class="text-skin-accent underline">"/now"</a
            > page or learn more about me on my <a
              href="/about"
              class="text-skin-accent underline">"/about"</a
            > page.
          </p>
        </p>
        {
          // only display if at least one social link is enabled
          socialCount > 0 && (
            <div class="social-wrapper">
              <div class="social-links">Social Links:</div>
              <Socials />
            </div>
          )
        }
      </div>

      <!-- {
        featuredPosts.length > 0 && (
          <>
            <section id="featured">
              <h2>Featured</h2>
              <ul>
                {featuredPosts.map(({ data, slug }) => (
                  <Card
                    href={`/blog/${slug}/`}
                    frontmatter={data}
                    secHeading={false}
                  />
                ))}
              </ul>
            </section>
            {recentPosts.length > 0 && <Hr />}
          </>
        )
      } -->

      <BlogStats />

      {
        recentPosts.length > 0 && (
          <section id="recent-posts">
            <h2>Recent Posts</h2>
            <ul class="mt-6">
              {recentPosts.map(
                ({ data, slug }, index) =>
                  index < 15 && (
                    <Card
                      href={`/blog/${slug}/`}
                      frontmatter={data}
                      secHeading={false}
                    />
                  )
              )}
            </ul>
          </section>
        )
      }

      <MostReadAndTopics />

      <section id="projects">
        <div class="projects-header">
          <h2>Projects</h2>
          <a href="/projects/" class="all-projects-link">all projects →</a>
        </div>
        <ul class="projects-grid">
          <li>
            <a href="/lasttimei" class="project-card">
              <img src="/lasttimei-icon.png" alt="Last Time I app icon" class="project-icon" />
              <div class="project-meta">
                <span class="project-name">Last Time I</span>
                <span class="project-kind">iOS App</span>
              </div>
            </a>
          </li>
          <li>
            <a href="/skillsbar" class="project-card">
              <img src="/skillsbar-icon.png" alt="SkillsBar app icon" class="project-icon" />
              <div class="project-meta">
                <span class="project-name">SkillsBar</span>
                <span class="project-kind">macOS Menubar</span>
              </div>
            </a>
          </li>
          <li>
            <a href="/muxbar" class="project-card">
              <img src="/muxbar-icon.png" alt="MuxBar app icon" class="project-icon" />
              <div class="project-meta">
                <span class="project-name">MuxBar</span>
                <span class="project-kind">macOS Menubar</span>
              </div>
            </a>
          </li>
        </ul>
      </section>
    </section>

    <Footer />
  </main>

  <style>
    /* ===== Hero Section ===== */
    #hero {
      @apply pb-8 pt-10;
    }
    #hero h1 {
      @apply my-4 inline-block font-serif text-3xl font-bold sm:my-8 sm:text-4xl;
    }
    #hero .rss-link {
      @apply mb-6;
    }
    #hero .rss-icon {
      @apply mb-2 h-6 w-6 scale-110 fill-skin-accent sm:mb-3 sm:scale-125;
    }
    #hero p {
      @apply my-2;
    }
    .username {
      background-color: rgb(var(--color-accent));
      color: #ffffff;
      padding: 5px 10px;
      display: inline-block;
      font-weight: bold;
      border-radius: 5px;
    }
    .social-wrapper {
      @apply mt-4 flex flex-col sm:flex-row sm:items-center;
    }
    .social-links {
      @apply mb-1 mr-2 whitespace-nowrap sm:mb-0;
    }

    /* ===== Featured & Recent Posts Sections ===== */
    #featured,
    #recent-posts {
      @apply pb-8 pt-14;
    }
    #featured h2,
    #recent-posts h2 {
      @apply font-serif text-2xl font-semibold tracking-wide;
    }
    /* ===== Projects Section ===== */
    #projects {
      @apply pb-8 pt-14;
    }
    .projects-header {
      @apply flex items-baseline justify-between;
    }
    #projects h2 {
      @apply font-serif text-2xl font-semibold tracking-wide;
    }
    .all-projects-link {
      @apply font-mono text-xs text-skin-base opacity-60 transition-opacity hover:text-skin-accent hover:opacity-100;
    }
    .projects-grid {
      @apply mt-6 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-3;
    }
    .project-card {
      @apply flex h-full items-center gap-3 rounded-lg border border-skin-line bg-skin-card px-4 py-3 no-underline transition-colors hover:border-skin-accent;
    }
    .project-icon {
      @apply h-10 w-10 shrink-0 rounded-[10px];
    }
    .project-meta {
      @apply flex min-w-0 flex-col;
    }
    .project-name {
      @apply font-serif text-base font-semibold text-skin-base;
    }
    .project-kind {
      @apply font-mono text-[10px] uppercase tracking-widest text-skin-base opacity-50;
    }
  </style>
</Layout>
