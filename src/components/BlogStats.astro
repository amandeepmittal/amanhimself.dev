---
import { getCollection } from 'astro:content';
import { publishedPostFilter } from '@utils/postFilter';
import getUniqueTags from '@utils/getUniqueTags';
import Tag from '@components/Tag.astro';
import Hr from '@components/Hr.astro';
import blogStats from '@data/blogStats.json';

const posts = await getCollection('blog');
const publishedPosts = posts.filter(publishedPostFilter);
const totalPosts = publishedPosts.length;

// Build a slug -> post data map for most read posts
const slugToPost = new Map(
  publishedPosts.map(p => [p.slug, p.data])
);

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

function buildMostRead(entries: { slug: string; views: number }[]) {
  return entries
    .filter(p => slugToPost.has(p.slug))
    .map(p => {
      const data = slugToPost.get(p.slug)!;
      return {
        slug: p.slug,
        title: data.title,
        views: p.views,
        isNew: new Date(data.pubDatetime) > thirtyDaysAgo,
      };
    });
}

const mostRead = buildMostRead(blogStats.mostRead);
const mostRead365 = buildMostRead(blogStats.mostRead365 ?? []);

const excludedTags = new Set(['ionic']);
const topTags = getUniqueTags(publishedPosts)
  .filter(t => !excludedTags.has(t.tag))
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

function formatNumber(num: number): string {
  return num.toLocaleString('en-US');
}
---

<div class="blog-stats-wrapper">
  <a href="/blog/" class="blog-stats-card group">
    <div class="blog-stats-content">
      <h2 class="blog-stats-heading">Blog</h2>
      <p class="blog-stats-text">
        My <strong>{totalPosts}</strong> blog posts have been read <strong
          >{formatNumber(blogStats.pageviews)}</strong
        > times by <strong>{formatNumber(blogStats.visitors)}</strong> visitors since
        2019. You'll find posts about React Native, Expo, docs tooling, tech writing, LLMs, and more.
      </p>
      <div class="blog-stats-cta">
        <span>Start reading the blog</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="blog-stats-arrow"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </div>
    </div>
  </a>

  {(mostRead.length > 0 || mostRead365.length > 0) && (
    <section class="most-read">
      <div class="flex items-center justify-between gap-4">
        <h2 class="most-read-heading">Most Read</h2>
        {mostRead.length > 0 && mostRead365.length > 0 && (
          <div class="most-read-tabs" role="tablist">
            <button role="tab" aria-selected="true" data-tab="90" class="most-read-tab most-read-tab-active">90 days</button>
            <button role="tab" aria-selected="false" data-tab="365" class="most-read-tab">365 days</button>
          </div>
        )}
      </div>
      <ul id="most-read-90" role="tabpanel">
        {mostRead.map(post => (
          <li class="my-8">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex flex-wrap items-center gap-2">
                <a
                  href={`/blog/${post.slug}/`}
                  class="inline-block text-lg font-medium text-skin-accent decoration-solid underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0"
                >
                  <h3 class="text-lg font-medium decoration-solid hover:underline">
                    {post.title}
                  </h3>
                </a>
                {post.isNew && (
                  <span class="rounded bg-green-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-green-800 dark:bg-green-900 dark:text-green-200">
                    New
                  </span>
                )}
              </div>
              <div class="sm:ml-4 sm:shrink-0">
                <div class="flex items-center space-x-2 opacity-80">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="inline-block h-6 w-6 scale-75 fill-skin-base opacity-60"
                    aria-hidden="true"
                  >
                    <path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"></path>
                  </svg>
                  <span class="text-xs italic text-skin-base opacity-60">
                    {formatNumber(post.views)} reads
                  </span>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
      <ul id="most-read-365" role="tabpanel" class="hidden">
        {mostRead365.map(post => (
          <li class="my-8">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex flex-wrap items-center gap-2">
                <a
                  href={`/blog/${post.slug}/`}
                  class="inline-block text-lg font-medium text-skin-accent decoration-solid underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0"
                >
                  <h3 class="text-lg font-medium decoration-solid hover:underline">
                    {post.title}
                  </h3>
                </a>
                {post.isNew && (
                  <span class="rounded bg-green-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-green-800 dark:bg-green-900 dark:text-green-200">
                    New
                  </span>
                )}
              </div>
              <div class="sm:ml-4 sm:shrink-0">
                <div class="flex items-center space-x-2 opacity-80">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="inline-block h-6 w-6 scale-75 fill-skin-base opacity-60"
                    aria-hidden="true"
                  >
                    <path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"></path>
                  </svg>
                  <span class="text-xs italic text-skin-base opacity-60">
                    {formatNumber(post.views)} reads
                  </span>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <Hr />

  {topTags.length > 0 && (
    <section class="top-tags">
      <h2 class="top-tags-heading">Top Tags</h2>
      <ul class="mt-4 flex flex-wrap gap-1">
        {topTags.map(({ tag, count }) => <Tag {tag} count={count} size="sm" />)}
      </ul>
    </section>
  )}
</div>

<style>
  .blog-stats-card {
    @apply mt-4 flex rounded-lg border border-skin-line bg-skin-card p-6 no-underline transition-all hover:border-skin-accent;
  }
  .blog-stats-content {
    @apply flex flex-col gap-3;
  }
  .blog-stats-heading {
    @apply font-serif text-2xl font-semibold tracking-wide text-skin-base;
  }
  .blog-stats-text {
    @apply text-skin-base opacity-80;
  }
  .blog-stats-text strong {
    @apply font-bold text-skin-accent;
  }
  .blog-stats-cta {
    @apply mt-2 flex items-center gap-2 font-medium text-skin-accent;
  }
  .blog-stats-arrow {
    @apply h-6 w-6 fill-skin-accent transition-transform group-hover:translate-x-1;
  }
  .most-read {
    @apply pb-8 pt-14;
  }
  .most-read-heading {
    @apply font-serif text-2xl font-semibold tracking-wide;
  }
  .most-read-tabs {
    @apply flex shrink-0 gap-1 rounded-lg border border-skin-line p-1;
  }
  .most-read-tab {
    @apply cursor-pointer rounded-md px-2.5 py-0.5 text-xs text-skin-base opacity-60 transition-all;
  }
  .most-read-tab-active {
    @apply bg-skin-accent bg-opacity-10 font-medium opacity-100 text-skin-accent;
  }
  .top-tags {
    @apply pb-8 pt-6;
  }
  .top-tags-heading {
    @apply font-serif text-2xl font-semibold tracking-wide;
  }
</style>

<script is:inline data-astro-rerun>
  document.querySelectorAll('.most-read-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const range = tab.dataset.tab;
      document.querySelectorAll('.most-read-tab').forEach(t => {
        t.classList.remove('most-read-tab-active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('most-read-tab-active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById('most-read-90').classList.toggle('hidden', range !== '90');
      document.getElementById('most-read-365').classList.toggle('hidden', range !== '365');
    });
  });
</script>
