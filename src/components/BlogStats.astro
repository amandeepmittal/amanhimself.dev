---
import { getCollection } from 'astro:content';
import { publishedPostFilter } from '@utils/postFilter';
import getUniqueTags from '@utils/getUniqueTags';
import Tag from '@components/Tag.astro';
import Hr from '@components/Hr.astro';
import blogStats from '@data/blogStats.json';

const posts = await getCollection('blog');
const publishedPosts = posts.filter(publishedPostFilter);
const totalPosts = publishedPosts.length;

// Build a slug -> title map for most read posts
const slugToTitle = new Map(
  publishedPosts.map(p => [p.slug, p.data.title])
);

const mostRead = blogStats.mostRead
  .filter(p => slugToTitle.has(p.slug))
  .map(p => ({
    slug: p.slug,
    title: slugToTitle.get(p.slug)!,
    views: p.views,
  }));

const excludedTags = new Set(['ionic']);
const topTags = getUniqueTags(publishedPosts)
  .filter(t => !excludedTags.has(t.tag))
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

function formatNumber(num: number): string {
  return num.toLocaleString('en-US');
}
---

<div class="blog-stats-wrapper">
  <a href="/blog/" class="blog-stats-card group">
    <div class="blog-stats-content">
      <h2 class="blog-stats-heading">Blog</h2>
      <p class="blog-stats-text">
        My <strong>{totalPosts}</strong> blog posts have been read <strong
          >{formatNumber(blogStats.pageviews)}</strong
        > times by <strong>{formatNumber(blogStats.visitors)}</strong> visitors since
        2019. You'll find posts about React Native, Expo, docs tooling, tech writing, LLMs, and more.
      </p>
      <div class="blog-stats-cta">
        <span>Start reading the blog</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="blog-stats-arrow"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </div>
    </div>
  </a>

  {mostRead.length > 0 && (
    <section class="most-read">
      <h2 class="most-read-heading">
        Most Read <span class="text-sm font-normal opacity-60">last 90 days</span>
      </h2>
      <ul>
        {mostRead.map(post => (
          <li class="my-8">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <a
                href={`/blog/${post.slug}/`}
                class="inline-block text-lg font-medium text-skin-accent decoration-solid underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0"
              >
                <h3 class="text-lg font-medium decoration-solid hover:underline">
                  {post.title}
                </h3>
              </a>
              <div class="sm:ml-4 sm:shrink-0">
                <div class="flex items-center space-x-2 opacity-80">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="inline-block h-6 w-6 scale-75 fill-skin-base"
                    aria-hidden="true"
                  >
                    <path d="M12 9a3.02 3.02 0 0 0-3 3c0 1.66 1.34 3 3 3s3-1.34 3-3-1.34-3-3-3z"></path>
                    <path d="M12 5c-7.633 0-9.927 6.617-9.948 6.684L1.946 12l.106.316C2.073 12.383 4.367 19 12 19s9.927-6.617 9.948-6.684l.106-.316-.106-.316C21.927 11.617 19.633 5 12 5zm0 12c-5.351 0-7.424-3.846-7.926-5C4.578 10.842 6.652 7 12 7c5.351 0 7.424 3.846 7.926 5-.504 1.158-2.578 5-7.926 5z"></path>
                  </svg>
                  <span class="text-xs italic text-skin-base opacity-60">
                    {formatNumber(post.views)} reads
                  </span>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <Hr />

  {topTags.length > 0 && (
    <section class="top-tags">
      <h2 class="top-tags-heading">Top Tags</h2>
      <ul class="mt-4 flex flex-wrap gap-1">
        {topTags.map(({ tag, count }) => <Tag {tag} count={count} size="sm" />)}
      </ul>
    </section>
  )}
</div>

<style>
  .blog-stats-card {
    @apply mt-4 flex rounded-lg border border-skin-line bg-skin-card p-6 no-underline transition-all hover:border-skin-accent;
  }
  .blog-stats-content {
    @apply flex flex-col gap-3;
  }
  .blog-stats-heading {
    @apply font-serif text-2xl font-semibold tracking-wide text-skin-base;
  }
  .blog-stats-text {
    @apply text-skin-base opacity-80;
  }
  .blog-stats-text strong {
    @apply font-bold text-skin-accent;
  }
  .blog-stats-cta {
    @apply mt-2 flex items-center gap-2 font-medium text-skin-accent;
  }
  .blog-stats-arrow {
    @apply h-6 w-6 fill-skin-accent transition-transform group-hover:translate-x-1;
  }
  .most-read {
    @apply pb-8 pt-14;
  }
  .most-read-heading {
    @apply font-serif text-2xl font-semibold tracking-wide;
  }
  .top-tags {
    @apply pb-8 pt-6;
  }
  .top-tags-heading {
    @apply font-serif text-2xl font-semibold tracking-wide;
  }
</style>
