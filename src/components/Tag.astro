---
export interface Props {
  tag: string;
  size?: 'sm' | 'lg';
  count?: number;
}

const { tag, size = 'sm', count } = Astro.props;
---

<li class="inline-block">
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class={`tag-chip ${size === 'lg' ? 'tag-chip-lg' : ''}`}
  >
    <span class="tag-name">#{tag}</span>
    {typeof count === 'number' && <span class="tag-count">{count}</span>}
  </a>
</li>

<style>
  .tag-chip {
    @apply inline-flex items-center gap-1.5 rounded-full border border-skin-line px-2.5 py-0.5 font-mono text-xs text-skin-base transition-colors hover:border-skin-accent hover:text-skin-accent;
  }
  .tag-chip-lg {
    @apply px-3 py-1 text-sm;
  }
  .tag-name {
    @apply tabular-nums;
  }
  .tag-count {
    @apply tabular-nums opacity-50;
  }
</style>
