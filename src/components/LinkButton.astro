---
export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
  class?: string;
}

// `class` carries the parent's scoped-style class. Astro 6 merged it into the
// rendered element implicitly; Astro 7 requires accepting it explicitly.
const {
  href,
  className,
  ariaLabel,
  title,
  disabled = false,
  class: scopedClass
} = Astro.props;
---

{
  disabled ? (
    <span
      class:list={['group inline-block', className, scopedClass]}
      aria-label={ariaLabel}
      title={title}
      aria-disabled={disabled}
    >
      <slot />
    </span>
  ) : (
    <a
      {href}
      class:list={[
        'group inline-block hover:text-skin-accent',
        className,
        scopedClass
      ]}
      aria-label={ariaLabel}
      title={title}
    >
      <slot />
    </a>
  )
}
